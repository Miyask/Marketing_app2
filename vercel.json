{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "build": {
    "env": {
      "NEXT_IGNORE_ESLINT": "1",
      "NEXT_TELEMETRY_DISABLED": "1"
    }
  },
  "functions": {
    "src/**/*.ts": {
      "maxDuration": 30
    }
  },
  "regions": ["iad1"],
  "cleanUrls": true,
  "trailingSlash": false
}
