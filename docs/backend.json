
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents an individual user of the MarketScout Pro application. This entity stores user-specific data, including AI preferences.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "fullName": {
          "type": "string",
          "description": "The full name of the user."
        },
        "aiSettings": {
          "type": "object",
          "properties": {
            "modelId": { "type": "string", "default": "googleai/gemini-1.5-flash" },
            "apiKey": { "type": "string", "description": "User's personal Google AI API Key" }
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "fullName",
        "createdAt"
      ]
    },
    "BusinessProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "BusinessProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "ownerName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "addressCity": { "type": "string" },
        "addressCountry": { "type": "string" },
        "industry": { "type": "string" },
        "leadStatus": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name", "leadStatus", "createdAt"]
    },
    "SearchQuery": {
      "title": "SearchQuery",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "searchDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name", "searchDate"]
    },
    "MarketingAsset": {
      "title": "MarketingAsset",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "targetBusinessProfileId": { "type": "string" },
        "assetType": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "targetBusinessProfileId", "assetType", "title", "content", "createdAt"]
    },
    "Campaign": {
      "title": "Campaign",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name", "startDate", "status", "createdAt"]
    },
    "Note": {
      "title": "Note",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "businessProfileId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "businessProfileId", "content", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores individual user profiles including AI preferences."
        }
      },
      {
        "path": "/users/{userId}/businessProfiles/{businessProfileId}",
        "definition": {
          "entityName": "BusinessProfile",
          "schema": {
            "$ref": "#/backend/entities/BusinessProfile"
          }
        }
      },
      {
        "path": "/users/{userId}/searchQueries/{searchQueryId}",
        "definition": {
          "entityName": "SearchQuery",
          "schema": {
            "$ref": "#/backend/entities/SearchQuery"
          }
        }
      },
      {
        "path": "/users/{userId}/marketingAssets/{marketingAssetId}",
        "definition": {
          "entityName": "MarketingAsset",
          "schema": {
            "$ref": "#/backend/entities/MarketingAsset"
          }
        }
      },
      {
        "path": "/users/{userId}/campaigns/{campaignId}",
        "definition": {
          "entityName": "Campaign",
          "schema": {
            "$ref": "#/backend/entities/Campaign"
          }
        }
      },
      {
        "path": "/users/{userId}/notes/{noteId}",
        "definition": {
          "entityName": "Note",
          "schema": {
            "$ref": "#/backend/entities/Note"
          }
        }
      }
    ]
  }
}
